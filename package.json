{
  "name": "monoorbit-ds",
  "version": "1.0.0",
  "description": "A modern Angular design system with 14 standalone components, design tokens, and Storybook documentation.",
  "author": "",
  "license": "MIT",
  "keywords": [
    "angular",
    "design-system",
    "components",
    "ui-kit",
    "storybook"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:app": "ng build monoorbit-ds",
    "build:lib": "ng build monoorbit-ds-lib",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "typecheck": "ngc -p tsconfig.app.json && ngc -p .storybook/tsconfig.json && ngc -p tsconfig.lib.json",
    "storybook": "ng run monoorbit-ds:storybook",
    "storybook:debug": "ng run monoorbit-ds:storybook --debug-webpack",
    "build-storybook": "ng run monoorbit-ds:build-storybook"
  },
  "private": false,
  "peerDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.22",
    "@angular/cli": "^20.3.22",
    "@angular/compiler-cli": "^20.3.18",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "storybook": "^10.3.3",
    "@storybook/angular": "^10.3.3",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "rxjs": "~7.8.0",
    "zone.js": "~0.15.0",
    "@angular-devkit/architect": "^0.2003.22",
    "@angular-devkit/core": "^20.3.22",
    "ng-packagr": "^20.3.0"
  }
}
